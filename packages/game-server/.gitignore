# ========================================
# GAME SERVER .gitignore
# ========================================
# Backend-specific ignores for game-server package

# ========================================
# CRITICAL: Environment & Secrets
# ========================================
.env
.env.local
.env.*.local
.env.production
.env.development

# Firebase credentials (VERY SENSITIVE!)
firebase-key.json
firebase-adminsdk-*.json
*.firebase.json
google-services.json

# ========================================
# Dependencies (Platform-specific!)
# ========================================
# Why ignore node_modules?
# - Contains OS-specific native bindings
# - Windows .dll, macOS .dylib, Linux .so files
# - Different per OS! Must regenerate per machine.
# - Can be 100MB+
#
# Solution: Keep package-lock.json, delete node_modules
# Next dev runs: npm install → reads package-lock.json
# → downloads correct binaries for THEIR OS
node_modules/
package-lock.json

# ========================================
# Logs & Debug Output
# ========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Server logs (if generated)
server.log
error.log
access.log

# ========================================
# IDE & Editor
# ========================================
.vscode/
.idea/
*.swp
*.swo
*.sw[a-z]
*~

# ========================================
# OS Files
# ========================================
.DS_Store
Thumbs.db
desktop.ini

# ========================================
# Build & Distribution
# ========================================
dist/
build/
*.tsbuildinfo

# ========================================
# Database (if using local DB)
# ========================================
*.db
*.sqlite
*.sqlite3
database.json

# ========================================
# Cache & Temporary
# ========================================
.cache/
.npm/
tmp/
temp/
*.tmp
*.temp
*.bak

# ========================================
# Testing
# ========================================
coverage/
.nyc_output/
*.lcov

# ========================================
# Node-specific
# ========================================
.node_repl_history
.eslintcache
