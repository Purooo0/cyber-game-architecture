/**
 * .env.example
 * Copy ini ke .env dan sesuaikan dengan konfigurasi Anda
 */

# Server Configuration
PORT=3000
NODE_ENV=development

# Initialize test users on server start (development only)
# Set to "true" to auto-create test users when server starts
# Set to "false" or omit to require proper user registration
INIT_TEST_USERS=false

# Client URL (untuk CORS)
CLIENT_URL=http://localhost:5173

# JWT Secret (generate dengan `openssl rand -base64 32`)
JWT_SECRET=your-secret-key-change-this

# Firebase Configuration
# Option 1: Menggunakan service account key file
FIREBASE_KEY_PATH=./firebase-key.json

# Option 2: Menggunakan environment variables
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Logging
LOG_LEVEL=debug
