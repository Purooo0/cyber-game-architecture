# ========================================
# GAME CLIENT .gitignore
# ========================================
# Frontend-specific ignores for game-client package

# Dependencies (inherited from root but specified here for clarity)
node_modules/
package-lock.json

# Build outputs
dist/
build/
.next/

# Environment (never commit secrets!)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Development
.cache/
.eslintcache
*.tsbuildinfo

# Browser cache
.cache_control/

# Vite-specific
.vite/

# Optional npm cache
.npm/

# Temporary files
*.tmp
*.temp
*.bak
